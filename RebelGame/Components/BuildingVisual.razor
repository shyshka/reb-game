@if (BuildingId == "wind_farm")
{
    <!-- Wind Farm: rotating turbine blades -->
    <svg viewBox="0 0 80 90" xmlns="http://www.w3.org/2000/svg" width="100%" height="100%">
        <rect width="80" height="90" fill="rgba(135,206,235,0.1)" rx="6"/>
        <rect y="76" width="80" height="14" fill="rgba(50,110,50,0.45)" rx="3"/>
        <!-- Tower -->
        <polygon points="38.5,76 41.5,76 41,42 39,42" fill="#b0b4bc"/>
        <!-- Rotating blades -->
        <g>
            <animateTransform attributeName="transform" type="rotate" from="0 40 40" to="360 40 40" dur="3s" repeatCount="indefinite"/>
            <path d="M40,40 C38,32 37.5,20 40,10 C42.5,20 42,32 40,40" fill="#dde8f4" stroke="#bcc8d8" stroke-width="0.4"/>
            <g transform="rotate(120 40 40)">
                <path d="M40,40 C38,32 37.5,20 40,10 C42.5,20 42,32 40,40" fill="#dde8f4" stroke="#bcc8d8" stroke-width="0.4"/>
            </g>
            <g transform="rotate(240 40 40)">
                <path d="M40,40 C38,32 37.5,20 40,10 C42.5,20 42,32 40,40" fill="#dde8f4" stroke="#bcc8d8" stroke-width="0.4"/>
            </g>
        </g>
        <!-- Hub -->
        <circle cx="40" cy="40" r="3.5" fill="#78808c"/>
    </svg>
}
else if (BuildingId == "solar_station")
{
    <!-- Solar Station: panel grid with pulsing sun glow -->
    <svg viewBox="0 0 80 80" xmlns="http://www.w3.org/2000/svg" width="100%" height="100%">
        <rect width="80" height="80" fill="rgba(135,206,235,0.08)" rx="6"/>
        <!-- Sun glow -->
        <circle cx="62" cy="18" r="14" fill="rgba(255,220,50,0.12)">
            <animate attributeName="r" values="12;17;12" dur="2.5s" repeatCount="indefinite"/>
            <animate attributeName="opacity" values="0.6;1;0.6" dur="2.5s" repeatCount="indefinite"/>
        </circle>
        <!-- Sun -->
        <circle cx="62" cy="18" r="7" fill="#FFD700"/>
        <!-- Panel frame -->
        <rect x="8" y="28" width="56" height="38" rx="3" fill="#1a2a4a" stroke="#2a4a7a" stroke-width="1.5"/>
        <!-- Panel cells grid -->
        <line x1="27" y1="28" x2="27" y2="66" stroke="#2a4a7a" stroke-width="1"/>
        <line x1="46" y1="28" x2="46" y2="66" stroke="#2a4a7a" stroke-width="1"/>
        <line x1="8"  y1="42" x2="64" y2="42" stroke="#2a4a7a" stroke-width="1"/>
        <line x1="8"  y1="54" x2="64" y2="54" stroke="#2a4a7a" stroke-width="1"/>
        <!-- Panel reflection shimmer -->
        <rect x="8" y="28" width="56" height="38" rx="3" fill="url(#shimmer)" opacity="0.3"/>
        <!-- Panel legs -->
        <rect x="24" y="64" width="4" height="10" fill="#607080"/>
        <rect x="50" y="64" width="4" height="10" fill="#607080"/>
        <!-- Ground base -->
        <rect x="16" y="72" width="46" height="4" rx="2" fill="rgba(50,110,50,0.6)"/>
    </svg>
}
else if (BuildingId == "power_plant")
{
    <!-- Power Plant: building with animated smoke -->
    <svg viewBox="0 0 80 90" xmlns="http://www.w3.org/2000/svg" width="100%" height="100%">
        <rect width="80" height="90" fill="rgba(100,100,120,0.08)" rx="6"/>
        <!-- Ground -->
        <rect y="76" width="80" height="14" fill="rgba(50,110,50,0.45)" rx="3"/>
        <!-- Main building -->
        <rect x="12" y="44" width="56" height="32" rx="3" fill="#3a4050"/>
        <rect x="12" y="40" width="56" height="6" rx="2" fill="#454a5c"/>
        <!-- Windows -->
        <rect x="20" y="52" width="10" height="8" rx="1" fill="#ffd060" opacity="0.9"/>
        <rect x="35" y="52" width="10" height="8" rx="1" fill="#ffd060" opacity="0.9"/>
        <rect x="50" y="52" width="10" height="8" rx="1" fill="#ffd060" opacity="0.7"/>
        <!-- Chimney 1 -->
        <rect x="22" y="20" width="10" height="24" rx="2" fill="#505060"/>
        <!-- Chimney 2 -->
        <rect x="48" y="26" width="10" height="18" rx="2" fill="#505060"/>
        <!-- Smoke from chimney 1 - puff 1 -->
        <circle cx="27" cy="20" r="5" fill="rgba(200,200,210,0.0)">
            <animate attributeName="cy" values="20;0;0" dur="2.2s" begin="0s" repeatCount="indefinite"/>
            <animate attributeName="r" values="4;8;8" dur="2.2s" begin="0s" repeatCount="indefinite"/>
            <animate attributeName="opacity" values="0;0.7;0" dur="2.2s" begin="0s" repeatCount="indefinite"/>
        </circle>
        <!-- Smoke from chimney 1 - puff 2 (staggered) -->
        <circle cx="27" cy="20" r="5" fill="rgba(200,200,210,0.0)">
            <animate attributeName="cy" values="20;0;0" dur="2.2s" begin="0.75s" repeatCount="indefinite"/>
            <animate attributeName="r" values="4;8;8" dur="2.2s" begin="0.75s" repeatCount="indefinite"/>
            <animate attributeName="opacity" values="0;0.7;0" dur="2.2s" begin="0.75s" repeatCount="indefinite"/>
        </circle>
        <!-- Smoke from chimney 2 - puff 1 -->
        <circle cx="53" cy="26" r="4" fill="rgba(200,200,210,0.0)">
            <animate attributeName="cy" values="26;6;6" dur="2s" begin="0.4s" repeatCount="indefinite"/>
            <animate attributeName="r" values="3;7;7" dur="2s" begin="0.4s" repeatCount="indefinite"/>
            <animate attributeName="opacity" values="0;0.65;0" dur="2s" begin="0.4s" repeatCount="indefinite"/>
        </circle>
        <!-- Smoke from chimney 2 - puff 2 (staggered) -->
        <circle cx="53" cy="26" r="4" fill="rgba(200,200,210,0.0)">
            <animate attributeName="cy" values="26;6;6" dur="2s" begin="1.4s" repeatCount="indefinite"/>
            <animate attributeName="r" values="3;7;7" dur="2s" begin="1.4s" repeatCount="indefinite"/>
            <animate attributeName="opacity" values="0;0.65;0" dur="2s" begin="1.4s" repeatCount="indefinite"/>
        </circle>
    </svg>
}
else if (BuildingId == "hunter_lodge")
{
    <!-- Hunter's Lodge: log cabin with smoke -->
    <svg viewBox="0 0 80 80" xmlns="http://www.w3.org/2000/svg" width="100%" height="100%">
        <rect width="80" height="80" fill="rgba(100,70,30,0.08)" rx="6"/>
        <!-- ground -->
        <rect y="67" width="80" height="13" fill="rgba(50,110,50,0.45)" rx="3"/>
        <!-- cabin walls -->
        <rect x="14" y="40" width="52" height="27" fill="#6b3a1f"/>
        <!-- log lines -->
        <line x1="14" y1="46" x2="66" y2="46" stroke="#8b5a2b" stroke-width="1.5"/>
        <line x1="14" y1="52" x2="66" y2="52" stroke="#8b5a2b" stroke-width="1.5"/>
        <line x1="14" y1="58" x2="66" y2="58" stroke="#8b5a2b" stroke-width="1.5"/>
        <line x1="14" y1="64" x2="66" y2="64" stroke="#8b5a2b" stroke-width="1.5"/>
        <!-- roof -->
        <polygon points="8,42 40,18 72,42" fill="#7a2000"/>
        <polygon points="10,42 40,21 70,42" fill="#9a3410"/>
        <!-- chimney -->
        <rect x="50" y="22" width="8" height="20" rx="1" fill="#705040"/>
        <!-- smoke puff 1 -->
        <circle cx="54" cy="22" r="4" fill="rgba(200,200,210,0)">
            <animate attributeName="cy"      values="22;4;4"     dur="2s" begin="0s"    repeatCount="indefinite"/>
            <animate attributeName="r"       values="3;7;7"      dur="2s" begin="0s"    repeatCount="indefinite"/>
            <animate attributeName="opacity" values="0;0.65;0"   dur="2s" begin="0s"    repeatCount="indefinite"/>
        </circle>
        <!-- smoke puff 2 (staggered) -->
        <circle cx="54" cy="22" r="4" fill="rgba(200,200,210,0)">
            <animate attributeName="cy"      values="22;4;4"     dur="2s" begin="0.85s" repeatCount="indefinite"/>
            <animate attributeName="r"       values="3;7;7"      dur="2s" begin="0.85s" repeatCount="indefinite"/>
            <animate attributeName="opacity" values="0;0.65;0"   dur="2s" begin="0.85s" repeatCount="indefinite"/>
        </circle>
        <!-- door -->
        <rect x="32" y="51" width="16" height="16" rx="2" fill="#3a1f0a"/>
        <circle cx="44" cy="60" r="1.5" fill="#c0a020"/>
        <!-- window -->
        <rect x="17" y="45" width="11" height="9" rx="1" fill="#a0c8e0" opacity="0.75"/>
        <line x1="22" y1="45" x2="22" y2="54" stroke="#607080" stroke-width="1"/>
        <line x1="17" y1="49" x2="28" y2="49" stroke="#607080" stroke-width="1"/>
    </svg>
}
else
{
    <!-- Fallback: emoji -->
    <span class="building-emoji">@(BuildingCatalog.GetById(BuildingId)?.Icon ?? "🏗️")</span>
}

@code {
    [Parameter, EditorRequired] public string BuildingId { get; set; } = string.Empty;
}
