    private static (double X, double Y, int Kind)[] MakeDecorations()
    {
        var rng = new Random(42);
        return Enumerable.Range(0, 130)
            .Select(_ => (rng.NextDouble() * 3880 + 60, rng.NextDouble() * 2280 + 60, rng.Next(3)))
            .ToArray();
    }

